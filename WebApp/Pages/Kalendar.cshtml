        var calendar;

        function appendLeadingZeroes(n) {
            if (n <= 9) {
                return "0" + n;
            }
            return n
        }

        function formatDate(date) {
            return appendLeadingZeroes(date.getDate()) + "." + (appendLeadingZeroes(date.getMonth() + 1)) + "." + date.getFullYear() + " " + appendLeadingZeroes(date.getHours()) + ":" + appendLeadingZeroes(date.getMinutes());
        }

        document.addEventListener('DOMContentLoaded', function () {
            var calendarEl = document.getElementById('calendar');

            calendar = new FullCalendar.Calendar(calendarEl, {
                plugins: ['dayGrid', 'googleCalendar'],
                googleCalendarApiKey: 'AIzaSyArm-QCSQ3yjE32rOnVw-83o0xhaCfbIxQ',
                locale: 'cs',
                eventClick: function (info) {
                    info.jsEvent.preventDefault(); // don't let the browser navigate
                },
                eventRender: function (info) {
                    $(info.el).tooltip({
                        html: true,
                        title: tmpl("tooltipTemplate", {
                            title: info.event.title,
                            date: formatDate(info.event.start) + " - " + formatDate(info.event.end),
                            place: info.event.extendedProps.location
                        })
                    });
                },
                eventTimeFormat: { // like '14:30:00'
                    hour: '2-digit',
                    minute: '2-digit'
                }
            });

            var legendGlobal =  $("#legend-global");
            var legendBaseball = $("#legend-baseball");
            var legendSoftball = $("#legend-softball");
            var switchStyles = $("#switchStyles");

            for (var i = 0; i < calendars.length; i++) {
                var c = calendars[i];
                var switchControl = tmpl("switchTemplate", c);
                if (c.category === "global") {
                    legendGlobal.append(switchControl);
                }
                else if (c.category === "baseball") {
                    legendBaseball.append(switchControl);
                }
                else {
                    legendSoftball.append(switchControl);
                }
                switchStyles.append(tmpl("switchClass", c));
                if (c.selected === true) {
                    calendar.addEventSource({
                        id: c.id,
                        googleCalendarId: c.googleCalendarId,
                        backgroundColor: c.backgroundColor,
                        borderColor: c.backgroundColor,
                        textColor: c.color
                    });
                }
            }
            calendar.render();
        });

        function switchChange(id, el) {
            if ($(el).prop("checked")) {
                for (var i = 0; i < calendars.length; i++) {
                    var c = calendars[i];
                    if (c.id === id) {
                        calendar.addEventSource({
                            id: c.id,
                            googleCalendarId: c.googleCalendarId,
                            backgroundColor: c.backgroundColor,
                            borderColor: c.backgroundColor,
                            textColor: c.color
                        });
                    }
                }
            }
            else {
                calendar.getEventSources().forEach(function (value, index, array) {
                    if (value.id === id) {
                        value.remove();
                    }
                })
            }
        }

        (function () {
            var cache = {};

            this.tmpl = function tmpl(str, data) {
                // Figure out if we're getting a template, or if we need to
                // load the template - and be sure to cache the result.
                var fn = !/\W/.test(str) ?
                    cache[str] = cache[str] ||
                    tmpl(document.getElementById(str).innerHTML) :

                    // Generate a reusable function that will serve as a template
                    // generator (and which will be cached).
                    new Function("obj",
                        "var p=[],print=function(){p.push.apply(p,arguments);};" +

                        // Introduce the data as local variables using with(){}
                        "with(obj){p.push('" +

                        // Convert the template into pure JavaScript
                        str
                            .replace(/[\r\t\n]/g, " ")
                            .split("<%").join("\t")
                            .replace(/((^|%>)[^\t]*)'/g, "$1\r")
                            .replace(/\t=(.*?)%>/g, "',$1,'")
                            .split("\t").join("');")
                            .split("%>").join("p.push('")
                            .split("\r").join("\\'")
                        + "');}return p.join('');");

                // Provide some basic currying to the user
                return data ? fn(data) : fn;
            };
        })();

    </script>
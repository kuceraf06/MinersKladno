@page
@model Miners.Web.WebApp.Pages.Kalendar

@section Head{
    <link href='~/lib/fullcalendar/core/main.css' rel='stylesheet' />
    <link href="~/css/kalendar.css" rel="stylesheet"/>
    <link href="~/css/pageshared.css" rel="stylesheet"/>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <script src='~/lib/fullcalendar/core/main.js'></script>
    <script src="~/lib/fullcalendar/core/locales/cs.js"></script>
    <script src="~/lib/fullcalendar/daygrid/main.js"></script>
    <script src='~/lib/fullcalendar/google-calendar/main.js'></script>
}
<div class="page-container">
    <h4>KALENDÁŘ</h4>
    <div  style="background-color: white; box-shadow: 0 4px 11px #00000040;" class="p-2">
        <h5>Miners kalendáře</h5>
        <div class="row" id="legend-global">
        </div><br />
        <h5>Baseball</h5>
        <div class="row" id="legend-baseball">
        </div><br />
        <h5>Softball</h5>
        <div class="row" id="legend-softball">
        </div><br />

        <div class="pt-2">
            <div id='calendar'></div>
        </div>
    </div>
</div>

<script type="text/html" id="switchTemplate">
    <div class="col-md-1 col-4">
        <div class="form-check form-switch">
            <input type="checkbox" class="form-check-input" id="switch-<%=id%>" onchange="switchChange('<%=id%>', this)" <%=selected ? 'checked' : ''%> />
            <label class="form-check-label text-nowrap" for="switch-<%=id%>"><%=title%></label>
        </div>
    </div>
</script>

<script type="text/html" id="switchClass">
    .switch-<%=id%> .custom-control-input:checked~.custom-control-label::before {
    color: <%=color%>;
    border-color: <%=backgroundColor%>;
    background-color: <%=backgroundColor%>;
    }
</script>
<script type="text/html" id="tooltipTemplate">
    <div>
        <div style="white-space:nowrap"><%=title%></div>
        <div style="white-space:nowrap"><%=date%></div>
        <div style="white-space:nowrap"><%=place%></div>
    </div>
</script>



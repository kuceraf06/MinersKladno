<script>
document.querySelectorAll('.matches').forEach(matchesBlock => {
  const matchesContainer = matchesBlock.querySelector('.matches-container');
  const prevBtn = matchesBlock.querySelector('.prevBtn');
  const nextBtn = matchesBlock.querySelector('.nextBtn');
  const match = matchesContainer.querySelector('.match');
  const remInPx = parseFloat(getComputedStyle(document.documentElement).fontSize);
  const matchWidth = match.offsetWidth;
  const containerStyle = getComputedStyle(matchesContainer);
  const gapRemContainer = parseFloat(containerStyle.gap) || 0;
  const gapPxContainer = gapRemContainer * remInPx;
  const scrollAmount = matchWidth + gapPxContainer;

  prevBtn.addEventListener('click', () => {
    matchesContainer.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
  });

  nextBtn.addEventListener('click', () => {
    matchesContainer.scrollBy({ left: scrollAmount, behavior: 'smooth' });
  });
});

</script>




